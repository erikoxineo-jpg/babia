# ============================================
# BarberFlow - Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
POSTGRES_USER=barberflow
POSTGRES_PASSWORD=TROCAR_POR_SENHA_FORTE
POSTGRES_DB=barberflow
DATABASE_URL=postgresql://barberflow:TROCAR_POR_SENHA_FORTE@barberflow-db:5432/barberflow

# ──────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────
NEXTAUTH_SECRET=TROCAR_POR_SECRET_GERADO
NEXTAUTH_URL=https://babia.oxineo.com.br

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
NODE_ENV=production

# ──────────────────────────────────────────
# Evolution API (WhatsApp)
# ──────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=TROCAR_POR_API_KEY
EVOLUTION_INSTANCE=barberflow
